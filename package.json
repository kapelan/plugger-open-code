{
  "name": "@sulesky/claude-marketplace",
  "version": "0.1.0",
  "description": "OpenCode plugin bringing the Claude Code plugin/marketplace ecosystem (commands, skills, MCP servers, hooks) into OpenCode",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "claude-code",
    "marketplace",
    "plugins"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "default": "./dist-tui/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "dist-tui",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsc && bun run build:tui",
    "build:tui": "bun build src-tui/index.tsx --outfile dist-tui/index.js --target=bun --external @opencode-ai/plugin --external @opentui/solid --external @opentui/core --external solid-js --external solid-js/web",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "semver": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.14.41",
    "@opentui/core": "^0.2.7",
    "@opentui/solid": "^0.2.7",
    "@types/node": "^25.6.2",
    "@types/semver": "^7.7.1",
    "bun-types": "^1.3.13",
    "solid-js": "^1.9.12",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
